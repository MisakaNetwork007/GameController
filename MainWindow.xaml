<Window
    x:Class="GameController.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GameController"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="手柄模拟器"
    Width="1280"
    Height="720"
    mc:Ignorable="d">
    <Window.Resources>
        <local:PointConverter x:Key="PointConverter" />
        <local:BoolToBrushConverter x:Key="BoolToBrushConverter" />
        <local:ValueToPointValueConverter x:Key="ValueToPointValueConverter" />
        <local:ValueToPercentageConverter x:Key="ValueToPercentageConverter" />
    </Window.Resources>
    <StackPanel>
        <StackPanel Margin="5" VerticalAlignment="Top" Orientation="Horizontal">
            <TextBlock FontSize="20" Text="设备名称" />
            <TextBox
                Margin="10,0,0,0"
                HorizontalAlignment="Left"
                FontSize="20"
                Text="{Binding DeviceName}" />
        </StackPanel>
        <StackPanel Margin="0" Orientation="Horizontal">
            <ComboBox
                Width="200"
                Margin="5"
                FontSize="20"
                SelectedIndex="{Binding DeviceProtocol}">
                <ComboBoxItem Content="DirectInput" />
                <ComboBoxItem Content="XInput" />
            </ComboBox>

            <Button
                Width="100"
                Margin="5"
                Command="{Binding StartConnectionCommand}"
                Content="连接"
                FontSize="20" />
            <Button
                Width="100"
                Margin="5"
                Command="{Binding StopConnectionCommand}"
                Content="断开连接"
                FontSize="20" />
        </StackPanel>
        <Grid Width="1000" Height="500" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="2*" />
            </Grid.RowDefinitions>

            <!--  电池外壳（圆角矩形）  -->
            <Rectangle
                x:Name="ke1"
                Margin="10"
                Fill="Transparent"
                RadiusX="5"
                RadiusY="5"
                Stroke="Black"
                StrokeThickness="2" />
            <Rectangle
                Height="{Binding ActualHeight, ElementName=ke1}"
                Margin="12"
                VerticalAlignment="Top"
                Fill="LightGreen"
                RadiusX="5"
                RadiusY="5">
                <Rectangle.RenderTransform>
                    <ScaleTransform CenterX="0" CenterY="0" ScaleX="1" ScaleY="{Binding LeftTriggerRotation, Converter={StaticResource ValueToPercentageConverter}}" />
                </Rectangle.RenderTransform>
            </Rectangle>

            <Rectangle
                Grid.Row="0"
                Grid.Column="1"
                Margin="30"
                Fill="{Binding IsLeftBumper, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Cyan,Transparent'}"
                RadiusX="5"
                RadiusY="5"
                Stroke="Black"
                StrokeThickness="2" />

            <StackPanel
                Grid.Row="0"
                Grid.Column="2"
                Margin="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Rectangle
                    Width="20"
                    Height="30"
                    Margin="10"
                    Fill="{Binding IsOptionsButton, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Cyan,Transparent'}"
                    RadiusX="5"
                    RadiusY="5"
                    Stroke="Black"
                    StrokeThickness="2" />
                <Rectangle
                    Width="200"
                    Height="120"
                    Margin="10"
                    Fill="{Binding IsTouchpadButton, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Cyan,Transparent'}"
                    RadiusX="5"
                    RadiusY="5"
                    Stroke="Black"
                    StrokeThickness="2" />
                <Rectangle
                    Width="20"
                    Height="30"
                    Margin="10"
                    Fill="{Binding IsHomeButton, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Cyan,Transparent'}"
                    RadiusX="5"
                    RadiusY="5"
                    Stroke="Black"
                    StrokeThickness="2" />
            </StackPanel>

            <Rectangle
                Grid.Row="0"
                Grid.Column="3"
                Margin="30"
                Fill="{Binding IsRightBumper, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Cyan,Transparent'}"
                RadiusX="5"
                RadiusY="5"
                Stroke="Black"
                StrokeThickness="2" />
            <!--  电池外壳（圆角矩形）  -->
            <Rectangle
                x:Name="ke2"
                Grid.Row="0"
                Grid.Column="4"
                Margin="10"
                Fill="Transparent"
                RadiusX="5"
                RadiusY="5"
                Stroke="Black"
                StrokeThickness="2" />
            <Rectangle
                Grid.Row="0"
                Grid.Column="4"
                Height="{Binding ActualHeight, ElementName=ke2}"
                Margin="12"
                VerticalAlignment="Top"
                Fill="LightGreen"
                RadiusX="5"
                RadiusY="5">
                <Rectangle.RenderTransform>
                    <ScaleTransform CenterX="0" CenterY="0" ScaleX="1" ScaleY="{Binding RightTriggerRotation, Converter={StaticResource ValueToPercentageConverter}}" />
                </Rectangle.RenderTransform>
            </Rectangle>

            <Grid
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Rectangle
                    Grid.Row="0"
                    Grid.Column="1"
                    Width="50"
                    Height="50"
                    Margin="10"
                    Fill="{Binding IsUpButton, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Cyan,Transparent'}"
                    RadiusX="5"
                    RadiusY="5"
                    Stroke="Black"
                    StrokeThickness="2" />
                <Rectangle
                    Grid.Row="1"
                    Grid.Column="2"
                    Width="50"
                    Height="50"
                    Margin="10"
                    Fill="{Binding IsRightButton, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Cyan,Transparent'}"
                    RadiusX="5"
                    RadiusY="5"
                    Stroke="Black"
                    StrokeThickness="2" />
                <Rectangle
                    Grid.Row="2"
                    Grid.Column="1"
                    Width="50"
                    Height="50"
                    Margin="10"
                    Fill="{Binding IsDownButton, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Cyan,Transparent'}"
                    RadiusX="5"
                    RadiusY="5"
                    Stroke="Black"
                    StrokeThickness="2" />
                <Rectangle
                    Grid.Row="1"
                    Grid.Column="0"
                    Width="50"
                    Height="50"
                    Margin="10"
                    Fill="{Binding IsLeftButton, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Cyan,Transparent'}"
                    RadiusX="5"
                    RadiusY="5"
                    Stroke="Black"
                    StrokeThickness="2" />
            </Grid>
            <Grid
                Grid.Row="1"
                Grid.Column="3"
                Grid.ColumnSpan="2"
                Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Rectangle
                    Grid.Row="0"
                    Grid.Column="1"
                    Width="50"
                    Height="50"
                    Margin="10"
                    Fill="{Binding IsYButton, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Cyan,Transparent'}"
                    RadiusX="5"
                    RadiusY="5"
                    Stroke="Black"
                    StrokeThickness="2" />
                <Rectangle
                    Grid.Row="1"
                    Grid.Column="2"
                    Width="50"
                    Height="50"
                    Margin="10"
                    Fill="{Binding IsBButton, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Cyan,Transparent'}"
                    RadiusX="5"
                    RadiusY="5"
                    Stroke="Black"
                    StrokeThickness="2" />
                <Rectangle
                    Grid.Row="2"
                    Grid.Column="1"
                    Width="50"
                    Height="50"
                    Margin="10"
                    Fill="{Binding IsAButton, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Cyan,Transparent'}"
                    RadiusX="5"
                    RadiusY="5"
                    Stroke="Black"
                    StrokeThickness="2" />
                <Rectangle
                    Grid.Row="1"
                    Grid.Column="0"
                    Width="50"
                    Height="50"
                    Margin="10"
                    Fill="{Binding IsXButton, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Cyan,Transparent'}"
                    RadiusX="5"
                    RadiusY="5"
                    Stroke="Black"
                    StrokeThickness="2" />
            </Grid>

            <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal">
                <Canvas Width="150" Margin="5">
                    <Ellipse
                        Canvas.Top="100"
                        Width="150"
                        Height="150"
                        Fill="{Binding IsLeftStick, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Cyan,LightGray'}"
                        Stroke="Black"
                        StrokeThickness="2" />
                    <Canvas
                        x:Name="elipse1"
                        Canvas.Top="100"
                        Width="150"
                        Height="150"
                        Margin="0">
                        <Ellipse
                            Canvas.Left="{Binding LeftX, Converter={StaticResource ValueToPointValueConverter}, ConverterParameter='150,10'}"
                            Canvas.Top="{Binding LeftY, Converter={StaticResource ValueToPointValueConverter}, ConverterParameter='150,10'}"
                            Width="10"
                            Height="10"
                            Fill="Red"
                            RenderTransformOrigin="0.5,0.5"
                            Stroke="Wheat"
                            StrokeThickness="2" />
                    </Canvas>
                </Canvas>
                <Rectangle
                    Width="25"
                    Height="25"
                    Margin="15"
                    Fill="{Binding IsStartButton, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Cyan,Transparent'}"
                    RadiusX="5"
                    RadiusY="5"
                    Stroke="Black"
                    StrokeThickness="2" />
                <Canvas Width="150" Margin="5">
                    <Ellipse
                        Canvas.Top="100"
                        Width="150"
                        Height="150"
                        Fill="{Binding IsRightStick, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='Cyan,LightGray'}"
                        Stroke="Black"
                        StrokeThickness="2" />
                    <Canvas
                        x:Name="elipse2"
                        Canvas.Top="100"
                        Width="150"
                        Height="150"
                        Margin="0">
                        <Ellipse
                            Canvas.Left="{Binding RightX, Converter={StaticResource ValueToPointValueConverter}, ConverterParameter='150,10'}"
                            Canvas.Top="{Binding RightY, Converter={StaticResource ValueToPointValueConverter}, ConverterParameter='150,10'}"
                            Width="10"
                            Height="10"
                            Fill="Red"
                            RenderTransformOrigin="0.5,0.5"
                            Stroke="Wheat"
                            StrokeThickness="2" />
                    </Canvas>
                </Canvas>
            </StackPanel>
        </Grid>
        <Grid Margin="20,10" VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                Grid.Column="0"
                Margin="5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock FontSize="20" Text="左摇杆" />
                <TextBox Width="200" FontSize="20" IsReadOnly="True">
                    <TextBox.Text>
                        <MultiBinding Converter="{StaticResource PointConverter}" UpdateSourceTrigger="LostFocus">
                            <!--  根据需要选择更新时机  -->
                            <Binding Mode="OneWay" Path="LeftX" />
                            <Binding Mode="OneWay" Path="LeftY" />
                        </MultiBinding>
                    </TextBox.Text>
                </TextBox>
            </StackPanel>
            <StackPanel
                Grid.Row="0"
                Grid.Column="1"
                Margin="5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock FontSize="20" Text="右摇杆" />
                <TextBox Width="200" FontSize="20" IsReadOnly="True">
                    <TextBox.Text>
                        <MultiBinding Converter="{StaticResource PointConverter}" UpdateSourceTrigger="LostFocus">
                            <!--  根据需要选择更新时机  -->
                            <Binding Mode="OneWay" Path="RightX" />
                            <Binding Mode="OneWay" Path="RightY" />
                        </MultiBinding>
                    </TextBox.Text>
                </TextBox>
            </StackPanel>
            <StackPanel
                Grid.Row="1"
                Grid.Column="0"
                Margin="5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock FontSize="20" Text="左扳机" />
                <TextBox
                    Width="200"
                    FontSize="20"
                    IsReadOnly="True"
                    Text="{Binding LeftTriggerRotation}" />
            </StackPanel>
            <StackPanel
                Grid.Row="1"
                Grid.Column="1"
                Margin="5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock FontSize="20" Text="右扳机" />
                <TextBox
                    Width="200"
                    FontSize="20"
                    IsReadOnly="True"
                    Text="{Binding RightTriggerRotation}" />
            </StackPanel>
        </Grid>
    </StackPanel>
</Window>
